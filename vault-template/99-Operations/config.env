# SPDX-License-Identifier: Apache-2.0
# 99-Operations/config.env
# Single source of vault parameters. Source this file before running any script.
# Every script reads configuration from these exports; never hardcode values.

# ---------------------------------------------------------------------------
# REQUIRED — set this to your vault's absolute path before first use
# ---------------------------------------------------------------------------
export VAULT_ROOT="${HOME}/Vault"

# Vault-local Python: if you install dependencies into a venv at $VAULT_ROOT/.venv
# (recommended — modern distros block `pip install` into the system Python under
# PEP 668), this puts that interpreter first on PATH. Harmless if no venv exists.
export PATH="$VAULT_ROOT/.venv/bin:$PATH"

# ---------------------------------------------------------------------------
# Pillars — the major, durable life-domains of THIS vault.
# This is the adopter's to define. The set below is an example; replace it
# with your own. See docs/USING-THIS-TEMPLATE.md for pillar candidacy criteria.
#
# Rules: lowercase, no spaces, space-separated. Each value becomes a Catalog MOC.
# Adding/removing a pillar ripples through every note's `pillars` field and the
# Catalog — easiest to change before the vault holds content.
# ---------------------------------------------------------------------------
export PILLARS="mental health financial social technology calling"

# ---------------------------------------------------------------------------
# Grade system — value only, never effort (CONST-03, ADR-0003)
# ---------------------------------------------------------------------------
export GRADES="coal bronze silver gold"

# Grades that auto-queue for the refine pipeline at Sort.
# bronze does not auto-refine; operator decides (override or slag).
export REFINE_GATE_GRADES="silver gold"

# ---------------------------------------------------------------------------
# Knowledge lifecycle
# ---------------------------------------------------------------------------
export KNOWLEDGE_STAGES="refined polished"

# Active effort statuses (Sites + Tailings). Spoil statuses are separate below.
export EFFORT_STATUSES="dig ore slagged"

# Terminal spoil statuses.
export SPOIL_STATUSES="spent waste"

# ---------------------------------------------------------------------------
# Daily close — controlled disposition vocabulary (close-daily ritual, ADR-0012).
# Every daily item resolves to exactly one of these at close; deterministic
# dispatch + close-lint validate against this set.
# ---------------------------------------------------------------------------
export DISPOSITIONS="claim site crucible banked slagged spoiled realized recorded passover"

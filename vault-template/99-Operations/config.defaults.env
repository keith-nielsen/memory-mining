# SPDX-License-Identifier: Apache-2.0
# 99-Operations/config.defaults.env
# FRAMEWORK DEFAULTS — public, tracked. Sourced FIRST.
#
# Personal / machine-specific values live in the gitignored 99-Operations/config.env,
# which sources THIS file first and then applies overrides (bash last-write-wins).
# Do NOT put personal or machine-specific values here — this file ships in the public
# framework repo. (Setup: `cp config.env.example config.env`, then edit config.env.)

# ---------------------------------------------------------------------------
# Pillars — the major, durable life-domains of THIS vault.
# This is the adopter's to define. The set below is an EXAMPLE default; override it
# in config.env (or edit here in your fork). See docs/USING-THIS-TEMPLATE.md.
# Rules: lowercase, no spaces, space-separated. Each value becomes a Catalog index.
# ---------------------------------------------------------------------------
export PILLARS="mental health financial social technology calling"

# ---------------------------------------------------------------------------
# Grade system — value only, never effort (CONST-03, ADR-0003)
# ---------------------------------------------------------------------------
export GRADES="coal bronze silver gold"

# Grades that auto-queue for the refine pipeline at Sort.
export REFINE_GATE_GRADES="silver gold"

# ---------------------------------------------------------------------------
# Knowledge lifecycle
# ---------------------------------------------------------------------------
export KNOWLEDGE_STAGES="refined polished"

# Active effort statuses (Sites + Tailings). Spoil statuses are separate below.
export EFFORT_STATUSES="dig ore slagged"

# Terminal spoil statuses.
export SPOIL_STATUSES="spent waste"

# ---------------------------------------------------------------------------
# Daily close — controlled disposition vocabulary (daily-close ritual, ADR-0012).
# ---------------------------------------------------------------------------
export DISPOSITIONS="claim site crucible banked slagged spoiled realized recorded passover"

# ---------------------------------------------------------------------------
# Publish guard — PRIVATE BY DEFAULT (INV-14; ADR-0018, ADR-0020).
# The pre-push hook (push-guard-script) DENIES every push unless the target remote
# matches PUSH_ALLOWLIST. Leave both allowlists EMPTY to keep the vault un-publishable.
#  - PUSH_ALLOWLIST: PRIVATE off-machine backups only — a remote here may receive the
#    FULL vault. NEVER add a public remote.
#  - PUBLIC_REMOTE_ALLOWLIST: a remote here may receive ONLY paths in
#    99-Operations/schemas/publish-manifest.json (framework only); any private path is
#    refused path-by-path. For a deliberate public FRAMEWORK mirror.
# Set VAULT_PUBLISH_GUARD=off only as a deliberate, conscious opt-out.
# ---------------------------------------------------------------------------
export VAULT_PUBLISH_GUARD="on"
export PUSH_ALLOWLIST=""
export PUBLIC_REMOTE_ALLOWLIST=""

# ---------------------------------------------------------------------------
# Path placeholder — MUST be overridden in config.env with your absolute path.
# ---------------------------------------------------------------------------
export VAULT_ROOT="${HOME}/Vault"

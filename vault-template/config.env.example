# config.env.example — copy to 99-Operations/config.env and adapt
# See docs/USING-THIS-TEMPLATE.md for full setup instructions.

export VAULT_ROOT="${HOME}/Vault"                        # CHANGE THIS
export PATH="$VAULT_ROOT/.venv/bin:$PATH"                # vault-local venv (recommended; harmless if absent)
export PILLARS="mental health financial social technology calling"  # REPLACE with your pillars
export GRADES="coal bronze silver gold"                  # do not change (CONST-03)
export REFINE_GATE_GRADES="silver gold"                  # do not change
export KNOWLEDGE_STAGES="refined polished"               # do not change
export EFFORT_STATUSES="prospect dig ore slagged"        # do not change
export SPOIL_STATUSES="spent waste"                      # do not change
export VAULT_PUBLISH_GUARD="on"                          # INV-14: keep ON (private by default)
export PUSH_ALLOWLIST=""                                 # INV-14: empty = deny all pushes; add a PRIVATE remote URL to opt in
